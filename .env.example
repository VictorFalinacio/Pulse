# SEGURANÇA
JWT_SECRET=seu_jwt_secret_muito_seguro_aqui_minimo_32_caracteres

# DATABASE
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/pulse?retryWrites=true&w=majority

# EMAIL (IMPORTANTE: Usar Google App Password, não a senha da conta)
# Como gerar Google App Password: https://myaccount.google.com/apppasswords
# - Ative 2-factor authentication na sua conta Google
# - Gere uma app password (escolha Mail e Windows/Linux)
# - Use essa senha aqui, não a senha da sua conta Google
EMAIL_USER=seu_email@gmail.com
EMAIL_PASS=sua_app_password_do_google

# AI
GEMINI_API_KEY=sua_chave_api_gemini_aqui

# PRODUCTION (VERCEL)
FRONTEND_URL=https://seu-projeto-pulse.vercel.app
ALLOWED_ORIGINS=https://seu-projeto-pulse.vercel.app,https://seu-dominio-custom.com

# ENVIRONMENT
NODE_ENV=production
PORT=3000


